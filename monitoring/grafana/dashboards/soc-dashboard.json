{
  "title": "SOC Entity Management",
  "uid": "soc-main",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Entities Saved (total)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(soc_entity_saved_total)", "legendFormat": "total" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2, "type": "stat", "title": "Events Processed (total)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(soc_events_processed_total)", "legendFormat": "total" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3, "type": "stat", "title": "HTTP Requests/s",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "req/s" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4, "type": "stat", "title": "HTTP Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m]))", "legendFormat": "errors/s" }],
      "options": { "colorMode": "background", "thresholds": { "steps": [{"color":"green","value":0},{"color":"red","value":0.1}] }, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Entities Saved by Type",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(soc_entity_saved_total[1m])", "legendFormat": "{{event_type}}" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Enrichment Duration (p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(soc_enrichment_duration_seconds_bucket[5m]))", "legendFormat": "p99" },
                  { "expr": "histogram_quantile(0.50, rate(soc_enrichment_duration_seconds_bucket[5m]))", "legendFormat": "p50" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "HTTP Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(http_server_requests_seconds_count[1m])", "legendFormat": "{{method}} {{uri}} {{status}}" }]
    },
    {
      "id": 8, "type": "timeseries", "title": "JVM Memory Usage",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "Heap Used" },
        { "expr": "jvm_memory_max_bytes{area=\"heap\"}", "legendFormat": "Heap Max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "JVM GC Pause Time",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum[1m])", "legendFormat": "{{action}} {{cause}}" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Thread Count",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "live" },
        { "expr": "jvm_threads_daemon_threads", "legendFormat": "daemon" }
      ]
    }
  ]
}
